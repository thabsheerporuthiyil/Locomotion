# Frontend API endpoints
#
# Defaults (if unset):
# - VITE_API_ORIGIN=http://localhost:8000
# - VITE_AI_ORIGIN=http://localhost:8001
#
# If you run the nginx gateway on port 80 (recommended for docker-compose),
# set both origins to `http://localhost`:
# VITE_API_ORIGIN=http://localhost
# VITE_AI_ORIGIN=http://localhost
# VITE_GOOGLE_CLIENT_ID=your_google_web_client_id
# VITE_FIREBASE_API_KEY=your_firebase_web_api_key

# VITE_API_ORIGIN=http://localhost:8000
# VITE_AI_ORIGIN=http://localhost:8001



