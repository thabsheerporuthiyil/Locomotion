# Frontend API endpoints
#
# Defaults (if unset):
# - VITE_API_ORIGIN=http://localhost:8000
# - VITE_AI_ORIGIN=http://localhost:8001
#
# If you run the nginx gateway on port 80 (recommended for docker-compose),
# set both origins to `http://localhost`:
# VITE_API_ORIGIN=http://localhost
# VITE_AI_ORIGIN=http://localhost
# VITE_GOOGLE_CLIENT_ID=your_google_web_client_id
#
# VITE_API_ORIGIN=http://localhost:8000
# VITE_AI_ORIGIN=http://localhost:8001

# Firebase web push configuration
# VITE_FIREBASE_API_KEY=your_firebase_web_api_key
# VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
# VITE_FIREBASE_PROJECT_ID=your-project-id
# VITE_FIREBASE_STORAGE_BUCKET=your-project.firebasestorage.app
# VITE_FIREBASE_MESSAGING_SENDER_ID=your_messaging_sender_id
# VITE_FIREBASE_APP_ID=your_firebase_app_id
# VITE_FIREBASE_VAPID_KEY=your_firebase_web_vapid_key

