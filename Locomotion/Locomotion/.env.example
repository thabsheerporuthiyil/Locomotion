# Core runtime
DEBUG=False
DJANGO_SECRET_KEY=your_django_secret_key
ALLOWED_HOSTS=your-api-domain.com,localhost
CORS_ALLOWED_ORIGINS=http://localhost:5173,https://your-frontend-domain.com
CSRF_TRUSTED_ORIGINS=http://localhost:5173,https://your-frontend-domain.com

# Database / cache / broker
POSTGRES_DB=locomotion
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_postgres_password
POSTGRES_HOST=db
POSTGRES_PORT=5432
REDIS_CACHE_URL=redis://redis:6379/1
CHANNEL_REDIS_URL=redis://redis:6379/1
CELERY_BROKER_URL=redis://redis:6379/0

# Django / app
GOOGLE_CLIENT_ID=your_google_web_client_id
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your_smtp_username
EMAIL_HOST_PASSWORD=your_smtp_app_password
DEFAULT_FROM_EMAIL=your_from_email
ORS_API_KEY=your_openrouteservice_api_key
RAZORPAY_KEY_ID=your_razorpay_key_id
RAZORPAY_KEY_SECRET=your_razorpay_key_secret

# AWS / storage / queue
AWS_REGION=eu-north-1
AWS_ACCESS_KEY_ID=your_aws_access_key_id
AWS_SECRET_ACCESS_KEY=your_aws_secret_access_key
AWS_STORAGE_BUCKET_NAME=your_s3_bucket_name
AWS_SQS_QUEUE_URL=your_sqs_queue_url
USE_S3=True
AWS_MEDIA_URL_EXPIRE_SECONDS=3600
AWS_MEDIA_CUSTOM_DOMAIN=

# Firebase Admin
FIREBASE_SERVICE_ACCOUNT_PATH=firebase-service-account.json

# AI service
AI_SERVICE_URL=http://fastapi-ai:8000
QDRANT_HOST=qdrant
QDRANT_PORT=6333
LLM_PROVIDER=gemini
GEMINI_API_KEY=
GROQ_API_KEY=
ALLOWED_ORIGINS=http://localhost:5173,https://your-frontend-domain.com
